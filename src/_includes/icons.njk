      <circle cx="4" cy="4" r="2" />
    </svg>
  {% elif name == "code" %}
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="m16 18 6-6-6-6" />
      <path d="m8 6-6 6 6 6" />
