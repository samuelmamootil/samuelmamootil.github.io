{% macro icon(name) %}
  {% if name == "award" %}
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M8 21h8" />
      <path d="M12 17v4" />
      <path d="M7 4h10v5a5 5 0 0 1-10 0V4Z" />
      <path d="M5 5H3v2a4 4 0 0 0 4 4" />
      <path d="M19 5h2v2a4 4 0 0 1-4 4" />
    </svg>
  {% elif name == "medal" %}
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="m8 3 4 6 4-6" />
      <path d="M10 3h4" />
      <circle cx="12" cy="15" r="5" />
      <path d="m10.5 15 1 1 2-2.5" />
