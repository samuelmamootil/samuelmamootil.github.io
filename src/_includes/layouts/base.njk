<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} | {{ site.title }}</title>
  <meta name="description" content="{{ site.description }}" />
  <meta name="author" content="{{ site.author }}" />
  <meta name="keywords" content="Samuel Mamootil, cloud engineer, DevOps engineer, platform engineer, cloud architect, AWS architect, Azure architect, GCP engineer, Terraform engineer, Kubernetes engineer, DevOps expert, AI infrastructure engineer, MLOps engineer, GenAI engineer, agentic AI infrastructure, cloud migration expert, FinOps engineer, cloud cost optimization, GitOps engineer, ArgoCD, AWS CDK, OpenTofu, serverless engineer, AWS Lambda, Azure Functions, Helm charts, Bicep IaC, Azure OpenAI engineer, international student USA, OPT engineer, H1B cloud engineer, sponsorship available, actively seeking cloud roles, green card engineer, master student cloud, UTA student, University of Texas Arlington, cloud computing expert, infrastructure as code, CI/CD expert, Docker Kubernetes, EKS AKS GKE, ECS Fargate, AWS SageMaker, Azure Machine Learning, AWS Bedrock, cloud security expert, zero trust networking, IAM expert, OIDC federation, web developer Arlington TX, site reliability engineer, SRE, platform engineering, enterprise cloud, multi-cloud architect, cloud engineer Texas, DevOps engineer Arlington TX" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

  <!-- Open Graph -->
  <meta property="og:title"       content="{{ title }} | {{ site.title }}" />
  <meta property="og:description" content="{{ site.description }}" />
  <meta property="og:url"         content="{{ site.url }}{{ page.url }}" />
  <meta property="og:type"        content="website" />
  <meta property="og:image"       content="{{ site.url }}/assets/img/gallery/linkedin.png" />
  <meta property="og:site_name"   content="{{ site.title }}" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="{{ title }} | {{ site.title }}" />
  <meta name="twitter:description" content="{{ site.description }}" />
  <meta name="twitter:image"       content="{{ site.url }}/assets/img/gallery/linkedin.png" />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "{{ site.url }}/#person",
        "name": "Samuel Mamootil",
        "url": "{{ site.url }}",
        "jobTitle": "Senior Cloud & Platform Engineer",
        "description": "Senior Cloud & Platform Engineer and DevOps expert with 7+ years of experience across AWS, Azure, and GCP. Master's student at University of Texas at Arlington. Specialises in cloud architecture, Terraform, Kubernetes, AI/ML infrastructure, and enterprise cloud migrations.",
        "image": "https://github.com/samuelmamootil.png",
        "email": "samuelrajumamootil@gmail.com",
        "sameAs": [
          "{{ site.linkedin }}",
          "{{ site.github }}",
          "https://samuelmamootil.github.io"
        ],
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Arlington",
          "addressRegion": "TX",
          "addressCountry": "US"
        },
        "alumniOf": {
          "@type": "CollegeOrUniversity",
          "name": "University of Texas at Arlington",
          "sameAs": "https://www.uta.edu"
        },
        "worksFor": {
          "@type": "Organization",
          "name": "UTA College of Business"
        },
        "knowsAbout": [
          "Cloud Architecture", "AWS", "Microsoft Azure", "Google Cloud Platform",
          "DevOps", "Platform Engineering", "Terraform", "Kubernetes", "Docker",
          "CI/CD", "GitHub Actions", "AI Infrastructure", "MLOps",
          "AWS SageMaker", "AWS Bedrock", "Azure Machine Learning",
          "Cloud Security", "IAM", "Zero Trust Networking", "Infrastructure as Code",
          "Cloud Migration", "Site Reliability Engineering", "EKS", "ECS Fargate"
        ],
        "hasCredential": [
          {
            "@type": "EducationalOccupationalCredential",
            "name": "Azure Solutions Architect Expert",
            "credentialCategory": "Professional Certification",
            "recognizedBy": { "@type": "Organization", "name": "Microsoft" }
          },
          {
            "@type": "EducationalOccupationalCredential",
            "name": "Azure DevOps Engineer Expert",
            "credentialCategory": "Professional Certification",
            "recognizedBy": { "@type": "Organization", "name": "Microsoft" }
          },
          {
            "@type": "EducationalOccupationalCredential",
            "name": "Azure Administrator Associate",
            "credentialCategory": "Professional Certification",
            "recognizedBy": { "@type": "Organization", "name": "Microsoft" }
          }
        ]
      },
      {
        "@type": "WebSite",
        "@id": "{{ site.url }}/#website",
        "url": "{{ site.url }}",
        "name": "{{ site.title }}",
        "description": "{{ site.description }}",
        "author": { "@id": "{{ site.url }}/#person" },
        "potentialAction": {
          "@type": "SearchAction",
          "target": "{{ site.url }}/writing/?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    ]
  }
  </script>

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-32x32.png" />

  <!-- Preconnect critical origins -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://api-gateway.umami.dev" />
  <link rel="preconnect" href="https://ipinfo.io" />
  <link rel="preconnect" href="https://api.open-meteo.com" />
  <link rel="preconnect" href="https://giscus.app" />

  <!-- Google Fonts — non-render-blocking -->
  {% if fontPreload %}<link rel="preload" as="font" type="font/woff2" href="https://fonts.gstatic.com/s/inter/v13/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuFuYAZJhiJ-Ek-_EeA.woff2" crossorigin />{% endif %}
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500;600&family=Caveat:wght@400;600;700&family=Permanent+Marker&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500;600&family=Caveat:wght@400;600;700&family=Permanent+Marker&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500;600&family=Caveat:wght@400;600;700&family=Permanent+Marker&display=swap" /></noscript>

  <!-- Main stylesheet — single link -->
  <link rel="stylesheet" href="/assets/css/style.css" />
</head>
<body data-sheet-url="{{ sheetWebhookUrl }}">

  <!-- NAV -->
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <div class="nav__inner">
      <a class="nav__logo" href="/">SM</a>
      <ul class="nav__links">
        <li><a href="/experience/">Work Experience</a></li>
        <li><a href="/projects/">Projects</a></li>
        <li><a href="/writing/">Blogs</a></li>
        <li><a href="/gallery/">Gallery</a></li>
        <li><a href="/media/">Visibility</a></li>
        <li><a href="{{ site.resume }}" class="resume-track">Resume</a></li>
      </ul>
      <button class="nav__toggle" id="navToggle" aria-label="Toggle menu">☰</button>
    </div>
  </nav>

  <!-- MOBILE DRAWER -->
  <div class="nav__drawer" id="navDrawer">
    <a href="/experience/">Work Experience</a>
    <a href="/projects/">Projects</a>
    <a href="/writing/">Blogs</a>
    <a href="/gallery/">Gallery</a>
    <a href="/media/">Visibility</a>
    <a href="{{ site.resume }}" class="resume-track">Resume</a>
  </div>

  <main id="main">
    {{ content | safe }}
  </main>

  <footer class="footer">
    <div class="container">
      <p>
        Built by Samuel Mamootil ·
        <a href="{{ site.linkedin }}" target="_blank" rel="noopener">LinkedIn</a> ·
        <a href="{{ site.github }}"   target="_blank" rel="noopener">GitHub</a>
        {% if site.instagram %} · <a href="{{ site.instagram }}" target="_blank" rel="noopener">Instagram</a>{% endif %}
      </p>
      <p class="footer__copy">&copy; {{ "" | year }} Samuel Mamootil</p>
    </div>
  </footer>

  <script defer src="https://cloud.umami.is/script.js" data-website-id="b753327d-567d-41d7-b831-2ecd1b01c445"></script>
  <script defer src="/assets/js/main.js"></script>
</body>
</html>