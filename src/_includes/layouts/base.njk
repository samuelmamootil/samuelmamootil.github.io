<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if page.url == '/' %}Samuel Mamootil — DevOps Engineer · Cloud Architect · ML Engineer | Portfolio{% else %}{{ title }} | {{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ pageDescription if pageDescription else (description if description else site.description) }}" />
  <meta name="author" content="{{ site.author }}" />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="keywords" content="Samuel Mamootil, Samuel Raju Mamootil, cloud engineer, DevOps engineer, platform engineer, site reliability engineer, SRE, cloud architect, AWS architect, Azure architect, GCP engineer, Terraform engineer, Kubernetes engineer, DevOps expert, AI infrastructure engineer, MLOps engineer, cloud migration expert, infrastructure as code, CI/CD expert, Docker Kubernetes, EKS AKS GKE, ECS Fargate, AWS SageMaker, Azure Machine Learning, AWS Bedrock, cloud security expert, zero trust networking, IAM expert, OIDC federation, Azure landing zones, Helm charts, multi-cloud architect, cloud engineer Texas, DevOps engineer Arlington TX, Azure DevOps engineer Arlington TX, site reliability engineer Arlington TX, cloud engineer portfolio Azure AWS Terraform, multi-cloud migration case study, Azure landing zone DevOps case study, AWS data engineering infrastructure case study, Samuel Mamootil DevOps, Samuel Mamootil Azure, Samuel Mamootil cloud engineer, Samuel Mamootil GitHub, UTA student, University of Texas Arlington" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

  <!-- Open Graph -->
  <meta property="og:title"       content="{% if page.url == '/' %}Samuel Mamootil — DevOps Engineer · Cloud Architect · ML Engineer | Portfolio{% else %}{{ title }} | {{ site.title }}{% endif %}" />
  <meta property="og:description" content="{{ pageDescription if pageDescription else (description if description else site.description) }}" />
  <meta property="og:url"         content="{{ site.url }}{{ page.url }}" />
  <meta property="og:type"        content="{% if layout == 'layouts/post.njk' %}article{% else %}website{% endif %}" />
  <meta property="og:image"       content="{{ site.url }}/assets/img/gallery/linkedin.png" />
  <meta property="og:site_name"   content="{{ site.title }}" />
  {% if layout == 'layouts/post.njk' %}
  <meta property="article:published_time" content="{{ date | isoDate }}" />
  <meta property="article:author"         content="{{ site.author }}" />
  {% endif %}

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="{% if page.url == '/' %}Samuel Mamootil — DevOps Engineer · Cloud Architect · ML Engineer | Portfolio{% else %}{{ title }} | {{ site.title }}{% endif %}" />
  <meta name="twitter:description" content="{{ pageDescription if pageDescription else (description if description else site.description) }}" />
  <meta name="twitter:image"       content="{{ site.url }}/assets/img/gallery/linkedin.png" />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "{{ site.url }}/#person",
        "name": "Samuel Mamootil",
        "alternateName": "Samuel Raju Mamootil",
        "url": "{{ site.url }}",
        "jobTitle": ["DevOps Engineer", "Cloud Architect", "Machine Learning Engineer"],
        "description": "Samuel Mamootil (Samuel Raju Mamootil) is a Cloud and Platform Engineer based in Arlington, TX. He specialises in AWS, Microsoft Azure, GCP, Terraform, Kubernetes, DevOps, and AI/ML infrastructure. He has delivered enterprise cloud migrations and platform engineering programs at IBM, Wipro, and LTIMindtree for clients including H&M, Siemens, Nokia, and Alight Solutions. Azure certified at Solutions Architect Expert, DevOps Engineer Expert, and Administrator Associate levels.",
        "image": "https://github.com/samuelmamootil.png",
        "email": "samuelrajumamootil@gmail.com",
        "sameAs": [
          "{{ site.linkedin }}",
          "{{ site.github }}",
          "https://samuelmamootil.github.io",
          "https://github.com/samuelmamootil/ReRhythm"
        ],
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Arlington",
          "addressRegion": "TX",
          "addressCountry": "US"
        },
        "alumniOf": {
          "@type": "CollegeOrUniversity",
          "name": "University of Texas at Arlington",
          "sameAs": "https://www.uta.edu"
        },
        "worksFor": {
          "@type": "Organization",
          "name": "UTA College of Business"
        },
        "knowsAbout": [
          "Cloud Architecture", "AWS", "Microsoft Azure", "Google Cloud Platform",
          "DevOps", "Platform Engineering", "Terraform", "Kubernetes", "Docker",
          "CI/CD", "GitHub Actions", "AI Infrastructure", "MLOps",
          "AWS SageMaker", "AWS Bedrock", "Azure Machine Learning",
          "Cloud Security", "IAM", "Zero Trust Networking", "Infrastructure as Code",
          "Cloud Migration", "Site Reliability Engineering", "EKS", "ECS Fargate"
        ],
        "hasCredential": [
          {
            "@type": "EducationalOccupationalCredential",
            "name": "Azure Solutions Architect Expert",
            "credentialCategory": "Professional Certification",
            "recognizedBy": { "@type": "Organization", "name": "Microsoft" }
          },
          {
            "@type": "EducationalOccupationalCredential",
            "name": "Azure DevOps Engineer Expert",
            "credentialCategory": "Professional Certification",
            "recognizedBy": { "@type": "Organization", "name": "Microsoft" }
          },
          {
            "@type": "EducationalOccupationalCredential",
            "name": "Azure Administrator Associate",
            "credentialCategory": "Professional Certification",
            "recognizedBy": { "@type": "Organization", "name": "Microsoft" }
          }
        ]
      },
      {
        "@type": "WebSite",
        "@id": "{{ site.url }}/#website",
        "url": "{{ site.url }}",
        "name": "{{ site.title }}",
        "description": "{{ site.description }}",
        "author": { "@id": "{{ site.url }}/#person" },
        "potentialAction": {
          "@type": "SearchAction",
          "target": "{{ site.url }}/writing/?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
      {% if page.url == '/' %}
      ,{
        "@type": "FAQPage",
        "@id": "{{ site.url }}/#faq",
        "mainEntity": [
          {% for item in site.faq %}
          {
            "@type": "Question",
            "name": "{{ item.q | replace('"', '&quot;') }}",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "{{ item.a | replace('"', '&quot;') }}"
            }
          }{% if not loop.last %},{% endif %}
          {% endfor %}
        ]
      }
      {% endif %}
      {% if layout == 'layouts/casestudy.njk' %}
      ,{
        "@type": "Article",
        "@id": "{{ site.url }}{{ page.url }}#article",
        "headline": "{{ headline }}",
        "description": "{{ pageDescription if pageDescription else site.description }}",
        "url": "{{ site.url }}{{ page.url }}",
        "author": { "@id": "{{ site.url }}/#person" },
        "publisher": { "@id": "{{ site.url }}/#person" },
        "isPartOf": { "@id": "{{ site.url }}/#website" }
      }
      {% endif %}
      {% if layout == 'layouts/post.njk' %}
      ,{
        "@type": "BlogPosting",
        "@id": "{{ site.url }}{{ page.url }}#article",
        "headline": "{{ title }}",
        "description": "{{ pageDescription if pageDescription else (description if description else site.description) }}",
        "url": "{{ site.url }}{{ page.url }}",
        "datePublished": "{{ date | isoDate }}",
        "author": { "@id": "{{ site.url }}/#person" },
        "publisher": { "@id": "{{ site.url }}/#person" },
        "isPartOf": { "@id": "{{ site.url }}/#website" }
      }
      {% endif %}
    ]
  }
  </script>

  <!-- Identity / rel=me -->
  <link rel="me" href="https://linkedin.com/in/samuel-mamootil" />
  <link rel="me" href="https://github.com/samuelmamootil" />
  <link rel="me" href="https://samuelmamootil.github.io" />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-32x32.png" />

  <!-- Preconnect critical origins -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://api-gateway.umami.dev" />
  <link rel="preconnect" href="https://ipinfo.io" />
  <link rel="preconnect" href="https://api.open-meteo.com" />
  <link rel="preconnect" href="https://giscus.app" />

  <!-- Google Fonts — non-render-blocking -->
  {% if fontPreload %}<link rel="preload" as="font" type="font/woff2" href="https://fonts.gstatic.com/s/inter/v13/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuFuYAZJhiJ-Ek-_EeA.woff2" crossorigin />{% endif %}
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500;600&family=Caveat:wght@400;600;700&family=Permanent+Marker&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500;600&family=Caveat:wght@400;600;700&family=Permanent+Marker&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500;600&family=Caveat:wght@400;600;700&family=Permanent+Marker&display=swap" /></noscript>

  <!-- Main stylesheet — single link -->
  <link rel="stylesheet" href="/assets/css/style.css" />
</head>
<body data-sheet-url="{{ sheetWebhookUrl }}">

  <!-- NAV -->
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <div class="nav__inner">
      <a class="nav__logo" href="/" aria-label="Samuel Mamootil — Home">SM</a>
      <ul class="nav__links">
        <li><a href="/work/">Experience</a></li>
        <li><a href="/projects/">Projects</a></li>
        <li><a href="/writing/">Writing</a></li>
        <li><a href="/gallery/">Gallery</a></li>
        <li><a href="/media/">Visibility</a></li>
        <li><a href="{{ site.resume }}" class="resume-track">Resume</a></li>
        <li><a href="/#contact" class="nav__contact-link">Contact</a></li>
      </ul>
      <button class="nav__toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="navDrawer">☰</button>
    </div>
  </nav>

  <!-- MOBILE DRAWER -->
  <div class="nav__drawer" id="navDrawer">
    <a href="/work/">Experience</a>
    <a href="/projects/">Projects</a>
    <a href="/writing/">Writing</a>
    <a href="/gallery/">Gallery</a>
    <a href="/media/">Visibility</a>
    <a href="{{ site.resume }}" class="resume-track">Resume</a>
    <a href="/#contact">Contact</a>
  </div>

  <main id="main">
    {{ content | safe }}
  </main>

  <footer class="footer" itemscope itemtype="https://schema.org/Person">
    <div class="container">
      <p>
        <span itemprop="name">Samuel Mamootil</span> &middot;
        <a href="{{ site.linkedin }}" target="_blank" rel="noopener" itemprop="sameAs">LinkedIn</a> &middot;
        <a href="{{ site.github }}" target="_blank" rel="noopener" itemprop="sameAs">GitHub</a>
        {% if site.instagram %} &middot; <a href="{{ site.instagram }}" target="_blank" rel="noopener" itemprop="sameAs">Instagram</a>{% endif %}
      </p>
      <p class="footer__copy">&copy; {{ "" | year }} Samuel Mamootil &middot; DevOps Engineer &middot; Cloud Architect &middot; Arlington, TX</p>
    </div>
  </footer>

  <script defer src="https://cloud.umami.is/script.js" data-website-id="b753327d-567d-41d7-b831-2ecd1b01c445"></script>
  <script src="https://unpkg.com/@formspree/ajax@1" defer></script>
  <script defer src="/assets/js/main.js"></script>
</body>
</html>