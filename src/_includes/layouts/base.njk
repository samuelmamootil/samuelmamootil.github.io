<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} | {{ site.title }}</title>
  <meta name="description" content="{{ site.description }}" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

  <!-- Open Graph -->
  <meta property="og:title"       content="{{ title }} | {{ site.title }}" />
  <meta property="og:description" content="{{ site.description }}" />
  <meta property="og:url"         content="{{ site.url }}{{ page.url }}" />
  <meta property="og:type"        content="website" />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- Google Fonts — single request, all 4 fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500;600&family=Caveat:wght@400;600;700&family=Permanent+Marker&display=swap" rel="stylesheet" />

  <!-- Main stylesheet — single link -->
  <link rel="stylesheet" href="/assets/css/style.css" />
</head>
<body>

  <!-- NAV -->
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <div class="nav__inner">
      <a class="nav__logo" href="/">SM</a>
      <ul class="nav__links">
        <li><a href="/">Home</a></li>
        <li><a href="/experience/">Work Experience</a></li>
        <li><a href="/projects/">Projects</a></li>
        <li><a href="/writing/">Blogs</a></li>
        <li><a href="/gallery/">Gallery</a></li>
        <li><a href="/media/">Visibility</a></li>
        <li><a href="{{ site.resume }}" target="_blank" rel="noopener" class="btn btn--sm">Resume ↗</a></li>
      </ul>
      <button class="nav__toggle" id="navToggle" aria-label="Toggle menu">☰</button>
    </div>
  </nav>

  <!-- MOBILE DRAWER -->
  <div class="nav__drawer" id="navDrawer">
    <a href="/">Home</a>
    <a href="/experience/">Experience</a>
    <a href="/projects/">Projects</a>
    <a href="/writing/">Blogs</a>
    <a href="/gallery/">Gallery</a>
    <a href="/media/">Visibility</a>
    <a href="{{ site.resume }}" target="_blank" rel="noopener">Resume ↗</a>
  </div>

  <main id="main">
    {{ content | safe }}
  </main>

  <footer class="footer">
    <div class="container">
      <p>
        Built by Samuel Mamootil ·
        <a href="{{ site.linkedin }}" target="_blank" rel="noopener">LinkedIn</a> ·
        <a href="{{ site.github }}"   target="_blank" rel="noopener">GitHub</a>
        {% if site.instagram %} · <a href="{{ site.instagram }}" target="_blank" rel="noopener">Instagram</a>{% endif %}
      </p>
      <p class="footer__copy">&copy; {{ "" | year }} Samuel Mamootil</p>
    </div>
  </footer>

  <!-- Giscus comments -->
  <script src="https://giscus.app/client.js"
    data-repo="samuelmamootil/samuelmamootil.github.io"
    data-repo-id="R_kgDORjZhAg"
    data-category="Blog Comments"
    data-category-id="DIC_kwDORjZhAs4C4RW1"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="bottom"
    data-theme="light"
    data-lang="en"
    crossorigin="anonymous"
    async>
  </script>

  <script src="/assets/js/main.js"></script>
  <script defer src="/_vercel/insights/script.js"></script>
</body>
</html>