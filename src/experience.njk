---
layout: layouts/base.njk
title: Work Experience
---

<section class="section container">
  <p class="eyebrow">Career</p>
  <h1>Work Experience</h1>
  <p class="lead">7+ years across enterprise cloud programs, startup products, and academic research — spanning AWS, Azure, GCP, and AI infrastructure.</p>

  <div class="timeline">
    {% for job in experience %}
    <div class="timeline__item">
      <div class="timeline__marker"></div>
      <div class="timeline__card">
        <div class="timeline__header">
          {% if job.logoUrl %}
          <img src="{{ job.logoUrl }}" alt="{{ job.company }} logo" class="company-logo" width="40" height="40" onerror="this.style.display='none'" />
          {% else %}
          <span class="company-logo-text" style="background:{{ job.logoColor }}">{{ job.logoText }}</span>
          {% endif %}
          <div>
            <h2 class="timeline__role">{{ job.role }}</h2>
            <p class="timeline__company">
              <a href="{{ job.companyUrl }}" target="_blank" rel="noopener">{{ job.company }}</a>
              &middot; {{ job.location }} &middot; <span class="timeline__period">{{ job.period }}</span>
            </p>
          </div>
        </div>
        <p class="timeline__summary">{{ job.summary }}</p>
        {% if job.clients.length %}
        <p class="timeline__clients">
          <strong>Clients:</strong>
          {% for c in job.clients %}<span class="tag">{{ c }}</span> {% endfor %}
        </p>
        {% endif %}
        <div class="tag-list">
          {% for t in job.stack %}<span class="tag">{{ t }}</span>{% endfor %}
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

