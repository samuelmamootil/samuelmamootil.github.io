---
layout: layouts/base.njk
title: Gallery
permalink: /gallery/
---

<section class="gallery-hero">
  <div class="container gallery-hero__inner">
    <div class="gallery-hero__copy">
      <p class="eyebrow">Gallery</p>
      <h1>Moments from the field</h1>
      <p>Hackathon work, university events, team moments, and the people around the cloud and data platform journey.</p>
    </div>
    {% set featured = gallery[0] %}
    <article class="gallery-feature instax"
             data-image="{{ featured.image }}"
             data-caption="{{ featured.caption }}"
             data-date="{{ featured.date | readableDate }}"
             data-title="{{ featured.title }}">
      <img src="{{ featured.image }}" alt="{{ featured.title }}" loading="eager" />
      <div class="gallery-feature__body">
        <time>{{ featured.date | readableDate }}</time>
        <strong>{{ featured.caption }}</strong>
      </div>
    </article>
  </div>
</section>

<section class="gallery-section container">
  <div class="section-header">
    <div>
      <p class="eyebrow">Photo Journal</p>
      <h2>Selected highlights</h2>
    </div>
    <p class="gallery-section__count">{{ gallery.length }} photos</p>
  </div>
  <div class="gallery-timeline">
    <div class="gallery-timeline__line" aria-hidden="true"></div>
    {% for item in gallery %}
    <article class="gallery-timeline__item instax"
             data-image="{{ item.image }}"
             data-caption="{{ item.caption }}"
             data-date="{{ item.date | readableDate }}"
             data-title="{{ item.title }}">
      <div class="gallery-timeline__marker">
        <span>{{ loop.index }}</span>
      </div>
      <div class="gallery-timeline__card">
        <div class="gallery-timeline__media instax__frame">
          <img src="{{ item.image }}" alt="{{ item.title }}"
               loading="lazy" class="instax__photo"
               onerror="this.parentElement.style.background='#1e293b'" />
        </div>
        <div class="gallery-timeline__body instax__label">
          {% if item.date %}
            <time class="instax__date">{{ item.date | readableDate }}</time>
          {% endif %}
          <h3 class="instax__title">{{ item.title }}</h3>
          <p class="instax__caption" title="{{ item.caption }}">{{ item.caption }}</p>
        </div>
      </div>
    </article>
    {% endfor %}
  </div>
</section>

<!-- PHOTO CREDITS -->
<section class="section container gallery-credits">
  <div>
    <p class="eyebrow">Photo credits</p>
    <h2>With gratitude to UTA College of Business</h2>
    <p>
      Several photos in this gallery were taken by the <strong>UTA College of Business</strong> photography team. All rights belong to their respective owners.
    </p>
  </div>
  <div class="gallery-credits__links">
    <a href="https://www.flickr.com/photos/utabusiness/albums/72177720332491623/"
       target="_blank" rel="noopener" class="btn btn--ghost btn--sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="7" cy="12" r="4"/><circle cx="17" cy="12" r="4"/></svg>
      Flickr Album 1
    </a>
    <a href="https://www.flickr.com/photos/utabusiness/albums/72177720329911465/"
       target="_blank" rel="noopener" class="btn btn--ghost btn--sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="7" cy="12" r="4"/><circle cx="17" cy="12" r="4"/></svg>
      Flickr Album 2
    </a>
  </div>
</section>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox">
  <div class="lightbox__card">
    <button class="lightbox__close" id="lightboxClose">&times;</button>
    <div class="lightbox__img-wrap">
      <img src="" alt="" id="lightboxImg" class="lightbox__img" />
    </div>
    <div class="lightbox__info">
      <time class="lightbox__date" id="lightboxDate"></time>
      <h2 class="lightbox__title" id="lightboxTitle"></h2>
      <p class="lightbox__caption" id="lightboxCaption"></p>
    </div>
  </div>
</div>
