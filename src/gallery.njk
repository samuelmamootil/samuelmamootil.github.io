---
layout: layouts/base.njk
title: Gallery
permalink: /gallery/
---

<section class="photo-wall">
  <h1 class="photo-wall__heading">Gallery</h1>
  <div class="photo-wall__grid">
    {% for item in gallery %}
    <article class="instax instax--{{ loop.index }}">
      <div class="instax__pin"></div>
      <div class="instax__frame">
        <img
          src="{{ item.image }}"
          alt="{{ item.title }}"
          loading="lazy"
          class="instax__photo"
          onerror="this.parentElement.style.background='#1e293b'"
        />
      </div>
      <div class="instax__label">
        {% if item.date %}
          <time class="instax__date">{{ item.date | readableDate }}</time>
        {% endif %}
        <p class="instax__caption">{{ item.caption | truncate(40) }}</p>
      </div>
    </article>
    {% endfor %}
  </div>
</section>
