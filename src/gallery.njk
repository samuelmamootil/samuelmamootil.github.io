---
layout: layouts/base.njk
title: Gallery
permalink: /gallery/
---

<section class="photo-wall">
  <h1 class="photo-wall__heading">Gallery</h1>
  <div class="photo-wall__grid">
    {% for item in gallery %}
    <article class="instax"
             data-image="{{ item.image }}"
             data-caption="{{ item.caption }}"
             data-date="{{ item.date | readableDate }}"
             data-title="{{ item.title }}">
      <div class="instax__pin"></div>
      <div class="instax__frame">
        <img src="{{ item.image }}" alt="{{ item.title }}"
             loading="lazy" class="instax__photo"
             onerror="this.parentElement.style.background='#1e293b'" />
      </div>
      <div class="instax__label">
        {% if item.date %}
          <time class="instax__date">{{ item.date | readableDate }}</time>
        {% endif %}
        <p class="instax__caption" title="{{ item.caption }}">
  {{ item.caption | truncate(40) }}
</p>
      </div>
    </article>
    {% endfor %}
  </div>
</section>

<!-- PHOTO CREDITS -->
<section class="photo-credits">
  <p class="photo-credits__label">Photo credits</p>
  <p class="photo-credits__text">
    Several photos in this gallery were taken by the
    <strong>UTA College of Business</strong> photography team and are used with gratitude.
    All rights belong to their respective owners.
  </p>
  <div class="photo-credits__links">
    <a href="https://www.flickr.com/photos/utabusiness/albums/72177720332491623/"
       target="_blank" rel="noopener" class="photo-credits__link">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="7" cy="12" r="4"/><circle cx="17" cy="12" r="4"/></svg>
      UTA Business — Flickr Album 1
    </a>
    <a href="https://www.flickr.com/photos/utabusiness/albums/72177720329911465/"
       target="_blank" rel="noopener" class="photo-credits__link">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="7" cy="12" r="4"/><circle cx="17" cy="12" r="4"/></svg>
      UTA Business — Flickr Album 2
    </a>
  </div>
</section>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox">
  <div class="lightbox__card">
    <button class="lightbox__close" id="lightboxClose">&times;</button>
    <div class="lightbox__img-wrap">
      <img src="" alt="" id="lightboxImg" class="lightbox__img" />
    </div>
    <div class="lightbox__info">
      <time class="lightbox__date" id="lightboxDate"></time>
      <h2 class="lightbox__title" id="lightboxTitle"></h2>
      <p class="lightbox__caption" id="lightboxCaption"></p>
    </div>
  </div>
</div>
