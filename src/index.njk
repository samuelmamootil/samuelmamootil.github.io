---
layout: layouts/base.njk
title: Samuel Mamootil - DevOps Engineer | Portfolio
pageDescription: "Samuel Mamootil is a DevOps Engineer based in Austin, TX with 7+ years of AWS, Azure, GCP, Terraform, Python automation, CI/CD, DevSecOps, and cloud data platform experience. MS in Information Systems, UTA, May 2026."
fontPreload: true
---
{% import "icons.njk" as icons %}

<!-- HERO -->
<section class="hero">
  <div class="hero__inner container">
    <div class="hero__text">
      <p class="eyebrow">DevOps · AWS Data Platform · Cloud Automation · DevSecOps · Multicloud</p>
      <h1 class="hero__headline">Samuel Mamootil</h1>
      <p class="hero__subheadline">DevOps Engineer · AWS Data Platform · Cloud Automation · DevSecOps</p>
      <p class="hero__intro">{{ site.heroIntro }}</p>
      <div class="hero__proof" aria-label="Profile highlights">
        <div class="proof-pill proof-pill--sky">
          <span class="proof-pill__value">7+ yrs</span>
          <span class="proof-pill__label">Cloud delivery</span>
        </div>
        <div class="proof-pill proof-pill--teal">
          <span class="proof-pill__value">AWS · Azure · GCP</span>
          <span class="proof-pill__label">Multicloud platforms</span>
        </div>
        <div class="proof-pill proof-pill--violet">
          <span class="proof-pill__value">MS IS</span>
          <span class="proof-pill__label">UTA · May 2026</span>
        </div>
        <div class="proof-pill proof-pill--emerald">
          <span class="proof-pill__value">Austin, TX</span>
          <span class="proof-pill__label">Open to US roles</span>
        </div>
      </div>
      <div class="hero__cta">
        <a href="/work/" class="btn">View Experience</a>
        <a href="{{ site.resume }}" class="btn btn--ghost resume-track">Resume</a>
        <a href="{{ site.linkedin }}" target="_blank" rel="noopener" class="btn btn--ghost">LinkedIn</a>
        <a href="#contact" class="btn btn--ghost">Get in touch</a>
      </div>
    </div>
    <div class="hero__visual">
      <div class="hero__avatar">
        <img src="https://github.com/samuelmamootil.png"
             alt="Samuel Mamootil - DevOps Engineer based in Austin, TX with AWS, Azure, and GCP experience"
             width="220" height="220" />
      </div>
      <div class="hero-focus-card">
        <p class="hero-focus-card__label">Current Focus</p>
        <strong>AWS data platform automation</strong>
        <span>Terraform modules, Python workflows, governed data pipelines, and secure release patterns.</span>
      </div>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section class="section container" id="about">
  <p class="eyebrow">About Samuel Mamootil</p>
  <h2>DevOps Engineer · Cloud Automation · AWS Data Platforms - Austin, TX</h2>
  <div class="story-grid">
    {% for line in site.story %}<p>{{ line }}</p>{% endfor %}
  </div>
</section>

<!-- STRENGTHS -->
<section class="section container section--compact">
  <div class="section-header">
    <div>
      <p class="eyebrow">Operating Strengths</p>
      <h2>Cloud delivery with security, automation, and data context</h2>
    </div>
  </div>
  <div class="strength-grid">
    {% for strength in site.strengths %}
    <div class="strength-card">
      <span class="strength-card__index">0{{ loop.index }}</span>
      <p>{{ strength }}</p>
    </div>
    {% endfor %}
  </div>
</section>

<!-- EXPERIENCE -->
<section class="section section--alt" id="experience">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="eyebrow">Selected Work</p>
        <h2>Experience</h2>
      </div>
      <a href="/work/" class="btn btn--ghost btn--sm">All experience &rarr;</a>
    </div>
    <p class="section-lede">Each role is presented with the business context, technical challenge, architecture decisions, what I owned, and what changed. This is the depth behind the resume.</p>
    <div class="timeline">
      {% set cs = casestudies[0] %}
      <div class="timeline__item">
        <div class="timeline__marker"></div>
        <div class="timeline__card">
          <div class="timeline__header">
            <span class="company-logo-text" style="background:{{ cs.logoColor }}">{{ cs.logoText }}</span>
            <div>
              <h3 class="timeline__role">{{ cs.company }}</h3>
              <p class="timeline__company">
                <a href="{{ cs.companyUrl }}" target="_blank" rel="noopener">{{ cs.role }}</a>
                &middot; <span class="timeline__period">{{ cs.period }}</span>
              </p>
            </div>
          </div>
          <p class="timeline__summary">{{ cs.headline }}</p>
          <div class="tag-list" style="margin-bottom:.75rem;">
            {% for t in cs.tags | slice(0, 4) %}<span class="tag">{{ t }}</span>{% endfor %}
          </div>
          <a href="/work/{{ cs.slug }}/" class="btn btn--ghost btn--sm">Read case study &rarr;</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CAPABILITIES -->
<section class="section container">
  <p class="eyebrow">Capabilities</p>
  <h2>Cloud, DevOps &amp; data platform skills</h2>
  <div class="skills-grid" style="margin-top:1.5rem;">
    {% for category, items in site.skills %}
    <div class="skill-card">
      <h3>{{ category }}</h3>
      <ul class="tag-list">
        {% for item in items %}<li class="tag">{{ item }}</li>{% endfor %}
      </ul>
    </div>
    {% endfor %}
  </div>
</section>

<!-- AWARDS -->
<section class="section container" id="awards">
  <p class="eyebrow">Awards &amp; Recognition</p>
  <h2>Honors &amp; Awards</h2>
  <p class="section-lede">Recognition received for cloud engineering delivery, enterprise migration programs, and AI product development across AWS and Azure.</p>
  <div class="awards-list">

    <div class="award-card">
      <div class="award-card__icon">{{ icons.icon("award") }}</div>
      <div class="award-card__body">
        <p class="award-card__org">AWS Hackathon / UTA Symposium 2026</p>
        <h3 class="award-card__title">Second Runner Up - ReRhythm AI Application</h3>
        <p class="award-card__project">Project: ReRhythm</p>
        <p class="award-card__desc">Built ReRhythm as a generative AI platform using AWS Bedrock, Claude, ChromaDB, RAG, CloudFormation, and ECS. The platform ingests and analyzes document data to identify skill gaps and generate intelligent workflow recommendations.</p>
      </div>
    </div>

    <div class="award-card">
      <div class="award-card__icon">{{ icons.icon("medal") }}</div>
      <div class="award-card__body">
        <p class="award-card__org">University of Texas at Arlington</p>
        <h3 class="award-card__title">Maverick Advantage Certificate of Distinction</h3>
        <p class="award-card__project">UTA 2026</p>
        <p class="award-card__desc">Recognized by UTA in 2026 for completing the Maverick Advantage distinction.</p>
      </div>
    </div>

    <div class="award-card">
      <div class="award-card__icon">{{ icons.icon("team") }}</div>
      <div class="award-card__body">
        <p class="award-card__org">LTIMindtree · Best Team Award</p>
        <h3 class="award-card__title">Best Team Award</h3>
        <p class="award-card__project">Project: Parexel</p>
        <p class="award-card__desc">Received the LTIMindtree Best Team Award in 2019 for the Parexel project.</p>
      </div>
    </div>

  </div>
</section>

<!-- FEATURED PROJECT -->
<section class="section section--alt section--spotlight">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="eyebrow">Featured Project</p>
        <h2>ReRhythm - Generative AI Platform on AWS</h2>
      </div>
      <a href="/projects/" class="btn btn--ghost btn--sm">All projects &rarr;</a>
    </div>
    <a href="/projects/" class="rr-spotlight">
      <div class="rr-spotlight__img-wrap">
        <img src="/assets/img/gallery/reRhythm resume upload.png"
             alt="ReRhythm AI career coaching platform — resume upload screen"
             loading="lazy" class="rr-spotlight__img" />
        <div class="rr-spotlight__overlay"><span>View Project &rarr;</span></div>
      </div>
      <div class="rr-spotlight__body">
        <p class="rr-spotlight__award">Second Runner Up - AWS Hackathon / UTA Symposium 2026</p>
        <p class="rr-spotlight__desc">ReRhythm is a generative AI platform built with AWS Bedrock, Claude, ChromaDB, RAG, CloudFormation, and ECS. It ingests, processes, and analyzes complex document data to identify skill gaps and generate intelligent workflow recommendations.</p>
        <div class="tag-list">
          <span class="tag">AWS Bedrock</span>
          <span class="tag">Claude</span>
          <span class="tag">ChromaDB</span>
          <span class="tag">RAG</span>
          <span class="tag">CloudFormation</span>
          <span class="tag">ECS</span>
        </div>
      </div>
    </a>
  </div>
</section>

<!-- GALLERY PREVIEW -->
<section class="section container">
  <div class="section-header">
    <div>
      <p class="eyebrow">Moments</p>
      <h2>In the field</h2>
    </div>
    <a href="/gallery/" class="btn btn--ghost btn--sm">View all photos &rarr;</a>
  </div>
  <div class="hpt">
    <div class="hpt__line"></div>
    {% for item in gallery %}
    {% if loop.index <= 3 %}
    <a class="hpt__card" href="/gallery/">
      <div class="hpt__dot"></div>
      <div class="hpt__avatar">
        <img src="{{ item.image }}" alt="{{ item.title }}" loading="lazy" />
      </div>
      <time class="hpt__date">{{ item.date | readableDate }}</time>
      <strong class="hpt__title">{{ item.title }}</strong>
      <span class="hpt__caption">{{ item.caption }}</span>
    </a>
    {% endif %}
    {% endfor %}
  </div>
</section>

<!-- BLOG -->
<section class="section section--alt">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="eyebrow">Writing</p>
        <h2>Cloud, DevOps &amp; AI — from the blog</h2>
      </div>
      <a href="/writing/" class="btn btn--ghost btn--sm">All posts &rarr;</a>
    </div>
    <div class="post-list">
      {% for post in collections.posts %}
      {% if loop.index <= 3 %}
      <a class="post-card" href="{{ post.url }}">
        <img class="post-card__img" src="{{ post.data.tags | postImage }}" alt="{{ post.data.title }}" loading="lazy" />
        <div class="post-card__body">
          <p class="post-card__date">{{ post.date | readableDate }}</p>
          <h3>{{ post.data.title }}</h3>
          <p>{{ post.data.description }}</p>
        </div>
      </a>
      {% endif %}
      {% else %}
      <p>No posts yet.</p>
      {% endfor %}
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="section section--alt" id="contact">
  <div class="container">
    <p class="eyebrow">Contact</p>
    <h2>Get in touch</h2>
    <p class="section-lede">Open to DevOps Engineering, Cloud Engineering, Data Platform, DevSecOps, and related roles in the US. Based in Austin, TX.</p>
    <div class="contact-grid">
      <form class="contact-form" id="contactForm" action="https://formspree.io/f/mnjokoon" method="POST" novalidate data-email="{{ site.email }}">
        
        <div data-fs-error class="contact-form__status contact-form__status--error"></div>
        <div class="contact-form__row">
          <div class="form-group">
            <label for="contactName">Name</label>
            <input type="text" id="contactName" name="name" placeholder="Your name" required autocomplete="name" data-fs-field />
            <span data-fs-error="name" class="contact-form__field-error"></span>
          </div>
          <div class="form-group">
            <label for="contactEmail">Email</label>
            <input type="email" id="contactEmail" name="email" placeholder="your@email.com" required autocomplete="email" data-fs-field />
            <span data-fs-error="email" class="contact-form__field-error"></span>
          </div>
        </div>
        <div class="form-group">
          <label for="contactSubject">Subject</label>
          <input type="text" id="contactSubject" name="subject" placeholder="Role opportunity / Collaboration / Other" />
        </div>
        <div class="form-group">
          <label for="contactMessage">Message</label>
          <textarea id="contactMessage" name="message" rows="5" placeholder="Tell me what you're working on..." required data-fs-field></textarea>
          <span data-fs-error="message" class="contact-form__field-error"></span>
        </div>
        <div class="contact-form__footer">
          <button type="submit" class="btn" id="contactSubmit" data-fs-submit-btn>Send message</button>
          <p class="contact-form__status" id="contactStatus" aria-live="polite"></p>
        </div>
      </form>
      <div class="contact-aside">
        <div class="contact-aside__item">
          <span class="contact-aside__icon">{{ icons.icon("mail") }}</span>
          <div>
            <p class="contact-aside__label">Email</p>
            <a href="mailto:{{ site.email }}" class="contact-aside__value">{{ site.email }}</a>
          </div>
        </div>
        <div class="contact-aside__item">
          <span class="contact-aside__icon">{{ icons.icon("linkedin") }}</span>
          <div>
            <p class="contact-aside__label">LinkedIn</p>
            <a href="{{ site.linkedin }}" target="_blank" rel="noopener" class="contact-aside__value">samuel-mamootil</a>
          </div>
        </div>
        <div class="contact-aside__item">
          <span class="contact-aside__icon">{{ icons.icon("code") }}</span>
          <div>
            <p class="contact-aside__label">GitHub</p>
            <a href="{{ site.github }}" target="_blank" rel="noopener" class="contact-aside__value">samuelmamootil</a>
          </div>
        </div>
        <div class="contact-aside__item">
          <span class="contact-aside__icon">{{ icons.icon("map-pin") }}</span>
          <div>
            <p class="contact-aside__label">Location</p>
            <p class="contact-aside__value">{{ site.location }}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section container" id="faq">
  <p class="eyebrow">FAQ</p>
  <h2>Common questions</h2>
  <div class="faq-list">
    {% for item in site.faq %}
    <details class="faq-item">
      <summary class="faq-item__q">{{ item.q }}</summary>
      <p class="faq-item__a">{{ item.a }}</p>
    </details>
    {% endfor %}
  </div>
</section>
