---
layout: layouts/base.njk
title: Samuel Mamootil — DevOps Engineer · Cloud Architect · ML Engineer | Portfolio
pageDescription: "Samuel Mamootil is a DevOps Engineer, Cloud Architect, and Machine Learning Engineer in Arlington, TX. AWS, Azure, GCP, Terraform, Kubernetes, CI/CD, IaC, and AI infrastructure. Delivered at IBM, Wipro, and LTIMindtree. Azure certified. Open to DevOps, Cloud, and MLOps roles in the US."
fontPreload: true
---

<!-- HERO -->
<section class="hero">
  <div class="hero__inner container">
    <div class="hero__text">
      <p class="eyebrow">DevOps · Cloud Architecture · Machine Learning · AI Infrastructure</p>
      <h1 class="hero__headline">Samuel Mamootil</h1>
      <p class="hero__subheadline" aria-label="DevOps Engineer · Machine Learning Engineer · Cloud Architect">
        <span class="hero__role-static">I'm a </span><span id="heroRole" class="hero__role-typed" aria-hidden="true"></span><span class="hero__cursor" aria-hidden="true"></span>
      </p>
      <p class="hero__intro">{{ site.heroIntro }}</p>
      <div id="weatherWidget" class="weather-widget" hidden>
        <div class="weather-widget__current">
          <span id="weatherIcon"></span>
          <span id="weatherTemp" class="weather-widget__temp" title="Click to toggle °C / °F"></span>
          <span id="weatherCity"></span>
          <span class="weather-widget__sep">·</span>
          <span id="weatherDesc"></span>
        </div>
        <div id="weatherForecast" class="weather-widget__forecast"></div>
      </div>
      <div class="hero__cta">
        <a href="/work/" class="btn">View Experience</a>
        <a href="{{ site.resume }}" class="btn btn--ghost resume-track">Resume</a>
        <a href="{{ site.linkedin }}" target="_blank" rel="noopener" class="btn btn--ghost">LinkedIn</a>
        <a href="#contact" class="btn btn--ghost">Get in touch</a>
      </div>
    </div>
    <div class="hero__avatar">
      <img src="https://github.com/samuelmamootil.png"
           alt="Samuel Mamootil — DevOps Engineer, Cloud Architect, and Machine Learning Engineer, Arlington TX"
           width="220" height="220" />
    </div>
  </div>
</section>

<!-- ABOUT -->
<section class="section container" id="about">
  <p class="eyebrow">About Samuel Mamootil</p>
  <h2>DevOps Engineer · Cloud Architect · ML Engineer — Arlington, TX</h2>
  <div class="story-grid">
    {% for line in site.story %}<p>{{ line }}</p>{% endfor %}
  </div>
</section>

<!-- EXPERIENCE -->
<section class="section section--alt" id="experience">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="eyebrow">Selected Work</p>
        <h2>Experience</h2>
      </div>
      <a href="/work/" class="btn btn--ghost btn--sm">All experience &rarr;</a>
    </div>
    <p style="max-width:640px;margin-bottom:2rem;">Each role is presented with the business context, technical challenge, architecture decisions, what I owned, and what changed. This is the depth behind the resume.</p>
    <div class="timeline">
      {% set cs = casestudies[0] %}
      <div class="timeline__item">
        <div class="timeline__marker"></div>
        <div class="timeline__card">
          <div class="timeline__header">
            <span class="company-logo-text" style="background:{{ cs.logoColor }}">{{ cs.logoText }}</span>
            <div>
              <h3 class="timeline__role">{{ cs.company }}</h3>
              <p class="timeline__company">
                <a href="{{ cs.companyUrl }}" target="_blank" rel="noopener">{{ cs.role }}</a>
                &middot; <span class="timeline__period">{{ cs.period }}</span>
              </p>
            </div>
          </div>
          <p class="timeline__summary">{{ cs.headline }}</p>
          <div class="tag-list" style="margin-bottom:.75rem;">
            {% for t in cs.tags | slice(0, 4) %}<span class="tag">{{ t }}</span>{% endfor %}
          </div>
          <a href="/work/{{ cs.slug }}/" class="btn btn--ghost btn--sm">Read case study &rarr;</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CAPABILITIES -->
<section class="section container">
  <p class="eyebrow">Capabilities</p>
  <h2>Cloud, DevOps &amp; AI skills</h2>
  <div class="skills-grid" style="margin-top:1.5rem;">
    {% for category, items in site.skills %}
    <div class="skill-card">
      <h3>{{ category }}</h3>
      <ul class="tag-list">
        {% for item in items %}<li class="tag">{{ item }}</li>{% endfor %}
      </ul>
    </div>
    {% endfor %}
  </div>
</section>

<!-- CERTIFICATIONS -->
<section class="section section--alt">
  <div class="container">
    <p class="eyebrow">Certifications</p>
    <h2>Microsoft Azure certified</h2>
    <div class="cert-row">
      {% for cert in site.certifications %}
      <div class="cert-badge">
        <span class="cert-badge__code" style="color:{{ cert.color }}">{{ cert.code }}</span>
        <span class="cert-badge__name">{{ cert.name }}</span>
        <span class="cert-badge__issuer">{{ cert.issuer }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- AWARDS -->
<section class="section container" id="awards">
  <p class="eyebrow">Awards &amp; Recognition</p>
  <h2>Honors &amp; Awards</h2>
  <p style="max-width:640px;margin-bottom:2rem;">Recognition received for cloud engineering delivery, enterprise migration programs, and AI product development across AWS and Azure.</p>
  <div class="awards-list">

    <div class="award-card">
      <div class="award-card__icon">🏆</div>
      <div class="award-card__body">
        <p class="award-card__org">AWS Symposium · UTA Analytics Symposium 2026</p>
        <h3 class="award-card__title">Second Runner-Up — AWS Competition</h3>
        <p class="award-card__project">Project: ReRhythm</p>
        <p class="award-card__desc">Designed and deployed ReRhythm, an AI-powered career coaching platform built on AWS. Architected the full cloud infrastructure using ECS Fargate, DynamoDB, CloudFormation, and AWS Bedrock (Claude) — earning second runner-up recognition at the University of Texas at Arlington Analytics Symposium AWS competition.</p>
      </div>
    </div>

    <div class="award-card">
      <div class="award-card__icon">🥇</div>
      <div class="award-card__body">
        <p class="award-card__org">LTIMindtree · Best Team Award</p>
        <h3 class="award-card__title">Best Team — Gold</h3>
        <p class="award-card__project">Project: GenRE (Regeneron)</p>
        <p class="award-card__desc">Led the secure migration of 100+ enterprise applications from on-premises infrastructure to Microsoft Azure using a structured lift-and-shift approach. Delivered at scale with zero data loss, enforcing security controls and compliance standards throughout — recognised with the Gold Best Team award for cloud modernisation impact.</p>
      </div>
    </div>

    <div class="award-card">
      <div class="award-card__icon">🥉</div>
      <div class="award-card__body">
        <p class="award-card__org">LTIMindtree · Best Team Award</p>
        <h3 class="award-card__title">Best Team — Bronze</h3>
        <p class="award-card__project">Project: Parexel</p>
        <p class="award-card__desc">Delivered secure, automated infrastructure deployments on Microsoft Azure using ARM templates and Azure DevOps pipelines. Received the Bronze Best Team award in recognition of deployment reliability, automation quality, and strong client satisfaction from Parexel.</p>
      </div>
    </div>

  </div>
</section>

<!-- FEATURED PROJECT -->
<section class="section section--alt">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="eyebrow">Featured Project</p>
        <h2>ReRhythm — AI Career Coach on AWS</h2>
      </div>
      <a href="/projects/" class="btn btn--ghost btn--sm">All projects &rarr;</a>
    </div>
    <a href="/projects/" class="rr-spotlight">
      <div class="rr-spotlight__img-wrap">
        <img src="/assets/img/gallery/reRhythm resume upload.png"
             alt="ReRhythm AI career coaching platform — resume upload screen"
             loading="lazy" class="rr-spotlight__img" />
        <div class="rr-spotlight__overlay"><span>View Project &rarr;</span></div>
      </div>
      <div class="rr-spotlight__body">
        <p class="rr-spotlight__award">🏆 Second runner-up — AWS Competition, UTA Analytics Symposium 2026</p>
        <p class="rr-spotlight__desc">ReRhythm is an AI-powered career coaching platform that parses resumes with AWS Textract and generates a personalised 28-day roadmap via AWS Bedrock (Claude). Built on ECS Fargate, DynamoDB, and CloudFormation — a full-stack cloud and AI engineering project from architecture to deployment.</p>
        <div class="tag-list">
          <span class="tag">AWS Bedrock</span>
          <span class="tag">Textract</span>
          <span class="tag">ECS Fargate</span>
          <span class="tag">.NET</span>
          <span class="tag">DynamoDB</span>
          <span class="tag">CloudFormation</span>
        </div>
      </div>
    </a>
  </div>
</section>

<!-- GALLERY PREVIEW -->
<section class="section container">
  <div class="section-header">
    <div>
      <p class="eyebrow">Moments</p>
      <h2>In the field</h2>
    </div>
    <a href="/gallery/" class="btn btn--ghost btn--sm">View all photos &rarr;</a>
  </div>
  <div class="hpt">
    <div class="hpt__line"></div>
    {% for item in gallery %}
    {% if loop.index <= 3 %}
    <a class="hpt__card" href="/gallery/">
      <div class="hpt__dot"></div>
      <div class="hpt__avatar">
        <img src="{{ item.image }}" alt="{{ item.title }}" loading="lazy" />
      </div>
      <time class="hpt__date">{{ item.date | readableDate }}</time>
      <strong class="hpt__title">{{ item.title }}</strong>
      <span class="hpt__caption">{{ item.caption }}</span>
    </a>
    {% endif %}
    {% endfor %}
  </div>
</section>

<!-- BLOG -->
<section class="section section--alt">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="eyebrow">Writing</p>
        <h2>Cloud, DevOps &amp; AI — from the blog</h2>
      </div>
      <a href="/writing/" class="btn btn--ghost btn--sm">All posts &rarr;</a>
    </div>
    <div class="post-list">
      {% for post in collections.posts %}
      {% if loop.index <= 3 %}
      <a class="post-card" href="{{ post.url }}">
        <img class="post-card__img" src="{{ post.data.tags | postImage }}" alt="{{ post.data.title }}" loading="lazy" />
        <div class="post-card__body">
          <p class="post-card__date">{{ post.date | readableDate }}</p>
          <h3>{{ post.data.title }}</h3>
          <p>{{ post.data.description }}</p>
        </div>
      </a>
      {% endif %}
      {% else %}
      <p>No posts yet.</p>
      {% endfor %}
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="section section--alt" id="contact">
  <div class="container">
    <p class="eyebrow">Contact</p>
    <h2>Get in touch</h2>
    <p style="max-width:560px;margin-bottom:2rem;">Open to DevOps, Cloud Architecture, and ML Engineering roles in the US. Feel free to reach out about opportunities, collaborations, or just to connect.</p>
    <div class="contact-grid">
      <form class="contact-form" id="contactForm" action="https://formspree.io/f/mnjokoon" method="POST" novalidate data-email="{{ site.email }}">
        <div data-fs-success class="contact-form__success">✓ Message sent — I'll get back to you soon.</div>
        <div data-fs-error class="contact-form__status contact-form__status--error"></div>
        <div class="contact-form__row">
          <div class="form-group">
            <label for="contactName">Name</label>
            <input type="text" id="contactName" name="name" placeholder="Your name" required autocomplete="name" data-fs-field />
            <span data-fs-error="name" class="contact-form__field-error"></span>
          </div>
          <div class="form-group">
            <label for="contactEmail">Email</label>
            <input type="email" id="contactEmail" name="email" placeholder="your@email.com" required autocomplete="email" data-fs-field />
            <span data-fs-error="email" class="contact-form__field-error"></span>
          </div>
        </div>
        <div class="form-group">
          <label for="contactSubject">Subject</label>
          <input type="text" id="contactSubject" name="subject" placeholder="Role opportunity / Collaboration / Other" />
        </div>
        <div class="form-group">
          <label for="contactMessage">Message</label>
          <textarea id="contactMessage" name="message" rows="5" placeholder="Tell me what you're working on..." required data-fs-field></textarea>
          <span data-fs-error="message" class="contact-form__field-error"></span>
        </div>
        <div class="contact-form__footer">
          <button type="submit" class="btn" id="contactSubmit" data-fs-submit-btn>Send message</button>
          <p class="contact-form__status" id="contactStatus" aria-live="polite"></p>
        </div>
      </form>
      <div class="contact-aside">
        <div class="contact-aside__item">
          <span class="contact-aside__icon">✉️</span>
          <div>
            <p class="contact-aside__label">Email</p>
            <a href="mailto:{{ site.email }}" class="contact-aside__value">{{ site.email }}</a>
          </div>
        </div>
        <div class="contact-aside__item">
          <span class="contact-aside__icon">💼</span>
          <div>
            <p class="contact-aside__label">LinkedIn</p>
            <a href="{{ site.linkedin }}" target="_blank" rel="noopener" class="contact-aside__value">samuel-mamootil</a>
          </div>
        </div>
        <div class="contact-aside__item">
          <span class="contact-aside__icon">🐙</span>
          <div>
            <p class="contact-aside__label">GitHub</p>
            <a href="{{ site.github }}" target="_blank" rel="noopener" class="contact-aside__value">samuelmamootil</a>
          </div>
        </div>
        <div class="contact-aside__item">
          <span class="contact-aside__icon">📍</span>
          <div>
            <p class="contact-aside__label">Location</p>
            <p class="contact-aside__value">{{ site.location }}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section container" id="faq">
  <p class="eyebrow">FAQ</p>
  <h2>Common questions</h2>
  <div class="faq-list">
    {% for item in site.faq %}
    <details class="faq-item">
      <summary class="faq-item__q">{{ item.q }}</summary>
      <p class="faq-item__a">{{ item.a }}</p>
    </details>
    {% endfor %}
  </div>
</section>
