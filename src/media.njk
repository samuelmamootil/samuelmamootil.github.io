---
layout: layouts/base.njk
title: Visibility
permalink: /media/
---

<section class="section container">
  <p class="eyebrow">Press &amp; features</p>
  <h1>Where I've Been Visible</h1>
  <p class="lead">Moments where my work showed up in the world — features, demos, and press coverage.</p>

  <div class="media-grid">
    {% for item in media %}
    <div class="media-card media-card--{{ item.type }}">

      <p class="media-card__type">
        {% if item.type == "press" %}📰 PRESS
        {% elif item.type == "reel" %}📹 REEL
        {% elif item.type == "linkedin" %}💼 LINKEDIN
        {% else %}📸 INSTAGRAM{% endif %}
      </p>
      <p class="media-card__label">{{ item.label }}</p>
      <p class="media-card__desc">{{ item.description }}</p>

      {% if item.type == "press" %}
        <div class="press-card">
          {% if item.image %}
          <div class="press-card__img-wrap">
            <img src="{{ item.image }}" alt="{{ item.label }}" class="press-card__img" loading="lazy" />
          </div>
          {% endif %}
          <p class="press-card__publication">{{ item.publication }}</p>
          <p class="press-card__date">{{ item.date }}</p>
          <blockquote class="press-card__quote">&ldquo;{{ item.quote }}&rdquo;</blockquote>
          <a href="{{ item.url }}" target="_blank" rel="noopener" class="btn btn--sm" style="margin-top:1rem;">Read Article ↗</a>
        </div>
      {% elif item.type == "linkedin" %}
        <a href="{{ item.url }}" target="_blank" rel="noopener" class="li-card">
          <div class="li-card__header">
            <img src="{{ item.avatar }}" alt="{{ item.author }}" class="li-card__avatar" />
            <div>
              <p class="li-card__name">{{ item.author }}</p>
              <p class="li-card__meta">{{ item.authorTitle }}</p>
              <p class="li-card__meta">{{ item.date }}</p>
            </div>
          </div>
          <p class="li-card__body">{{ item.postText }}</p>
          {% if item.postImage %}
          <div class="li-card__img-wrap">
            <img src="{{ item.postImage }}" alt="{{ item.label }}" />
          </div>
          {% endif %}
          <div class="li-card__footer">
            <span class="li-card__cta">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#0a66c2"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              View on LinkedIn
            </span>
          </div>
        </a>
      {% elif item.embed %}
        <div class="media-card__embed">
          <blockquote
            class="instagram-media"
            data-instgrm-captioned
            data-instgrm-permalink="{{ item.embed }}{% if item.img_index %}?img_index={{ item.img_index }}&{% else %}?{% endif %}utm_source=ig_embed&utm_campaign=loading"
            data-instgrm-version="14">
          </blockquote>
        </div>
      {% elif item.url %}
        <a href="{{ item.url }}" target="_blank" rel="noopener" class="btn btn--sm" style="margin-top:.75rem">View ↗</a>
      {% else %}
        <span class="tag tag--subtle">Coming soon</span>
      {% endif %}

    </div>
    {% endfor %}
  </div>
</section>

<script async src="https://www.instagram.com/embed.js"></script>
