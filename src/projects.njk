---
layout: layouts/base.njk
title: Projects
---
<section class="section container">
  <p class="eyebrow">Work I've built</p>
  <h1>Projects</h1>

  {%- for p in projects %}

  {%- if p.images %}
  <!-- Featured project card with slideshow -->
  <div class="proj-featured">

    <!-- CSS Slideshow -->
    <div class="proj-slideshow">
      <input class="proj-slide__radio" type="radio" name="rr-slide" id="slide-1" checked />
      <input class="proj-slide__radio" type="radio" name="rr-slide" id="slide-2" />
      <input class="proj-slide__radio" type="radio" name="rr-slide" id="slide-3" />

      <div class="proj-slideshow__track">
        {%- for img in p.images %}
        <div class="proj-slide">
          <img src="{{ img.src }}" alt="{{ img.alt }}" loading="lazy" class="proj-slide__img" />
          <span class="proj-slide__label">{{ img.alt | replace("ReRhythm — ", "") }}</span>
        </div>
        {%- endfor %}
      </div>

      <div class="proj-slideshow__dots">
        <label for="slide-1" class="proj-slideshow__dot" aria-label="Slide 1"></label>
        <label for="slide-2" class="proj-slideshow__dot" aria-label="Slide 2"></label>
        <label for="slide-3" class="proj-slideshow__dot" aria-label="Slide 3"></label>
      </div>

      <label for="slide-2" class="proj-slideshow__arrow proj-slideshow__arrow--next" id="arr-1-next" aria-label="Next">›</label>
      <label for="slide-3" class="proj-slideshow__arrow proj-slideshow__arrow--next" id="arr-2-next" aria-label="Next">›</label>
      <label for="slide-1" class="proj-slideshow__arrow proj-slideshow__arrow--next" id="arr-3-next" aria-label="Next">›</label>

      <label for="slide-3" class="proj-slideshow__arrow proj-slideshow__arrow--prev" id="arr-1-prev" aria-label="Previous">‹</label>
      <label for="slide-1" class="proj-slideshow__arrow proj-slideshow__arrow--prev" id="arr-2-prev" aria-label="Previous">‹</label>
      <label for="slide-2" class="proj-slideshow__arrow proj-slideshow__arrow--prev" id="arr-3-prev" aria-label="Previous">‹</label>
    </div>

    <!-- Content -->
    <div class="proj-featured__body">
      <p class="eyebrow">{{ p.type }}</p>
      <h2 class="proj-featured__title">{{ p.name }}</h2>
      {% if p.highlight %}
      <p class="proj-featured__award">{{ p.highlight }}</p>
      {% endif %}
      <p class="proj-featured__summary">{{ p.summary }}</p>
      <div class="tag-list" style="margin-bottom:1.5rem;">
        {% for t in p.tags %}<span class="tag">{{ t }}</span>{% endfor %}
      </div>
      <a href="{{ p.url }}" target="_blank" rel="noopener" class="btn">View on GitHub ↗</a>
    </div>

  </div>

  {%- else %}
  <!-- Standard project card -->
  <div class="project-grid" style="margin-top:2rem;">
    <div class="project-card">
      <h2><a href="{{ p.url }}" target="_blank" rel="noopener">{{ p.name }} ↗</a></h2>
      <p class="project-card__type">{{ p.type }}</p>
      <p>{{ p.summary }}</p>
      {% if p.highlight %}<p class="project-card__highlight">{{ p.highlight }}</p>{% endif %}
      <div class="tag-list">
        {% for t in p.tags %}<span class="tag">{{ t }}</span>{% endfor %}
      </div>
    </div>
  </div>
  {%- endif %}

  {%- endfor %}

</section>
