---
layout: layouts/base.njk
title: Projects
pageDescription: "Samuel Mamootil's projects — including ReRhythm, an award-winning AI career coaching platform built on AWS Bedrock, ECS Fargate, and DynamoDB."
---
<section class="section container">
  <p class="eyebrow">Work I've built</p>
  <h1>Projects</h1>

  {%- for p in projects %}

  {%- if p.images %}
  <div class="proj-featured">

    <!-- Slideshow -->
    <div class="proj-slideshow" id="slideshow-{{ loop.index }}">
      <div class="proj-slideshow__track">
        {%- for img in p.images %}
        <div class="proj-slide" data-index="{{ loop.index0 }}"><img src="{{ img.src }}" alt="{{ img.alt }}" loading="lazy" class="proj-slide__img" /><span class="proj-slide__label">{{ img.label }}</span></div>
        {%- endfor %}
      </div>
      <button class="proj-slideshow__arrow proj-slideshow__arrow--prev" aria-label="Previous">&#8249;</button>
      <button class="proj-slideshow__arrow proj-slideshow__arrow--next" aria-label="Next">&#8250;</button>
      <div class="proj-slideshow__dots">
        {%- for img in p.images %}
        <button class="proj-slideshow__dot{% if loop.first %} active{% endif %}" aria-label="Slide {{ loop.index }}"></button>
        {%- endfor %}
      </div>
    </div>

    <!-- Content -->
    <div class="proj-featured__body">
      <p class="eyebrow">{{ p.type }}</p>
      <h2 class="proj-featured__title">{{ p.name }}</h2>
      {% if p.highlight %}<p class="proj-featured__award">{{ p.highlight }}</p>{% endif %}
      <p class="proj-featured__summary">{{ p.summary }}</p>
      <div class="tag-list" style="margin-bottom:1.5rem;">
        {% for t in p.tags %}<span class="tag">{{ t }}</span>{% endfor %}
      </div>
      <a href="{{ p.url }}" target="_blank" rel="noopener" class="btn">{{ p.btnLabel if p.btnLabel else "View on GitHub ↗" }}</a>
    </div>

  </div>

  {%- else %}
  <div class="project-grid" style="margin-top:2rem;">
    <div class="project-card">
      <h2><a href="{{ p.url }}" target="_blank" rel="noopener">{{ p.name }} ↗</a></h2>
      <p class="project-card__type">{{ p.type }}</p>
      <p>{{ p.summary }}</p>
      {% if p.highlight %}<p class="project-card__highlight">{{ p.highlight }}</p>{% endif %}
      <div class="tag-list">
        {% for t in p.tags %}<span class="tag">{{ t }}</span>{% endfor %}
      </div>
    </div>
  </div>
  {%- endif %}

  {%- endfor %}

</section>

<script>
document.querySelectorAll('.proj-slideshow').forEach(function(ss) {
  var slides = ss.querySelectorAll('.proj-slide');
  var dots   = ss.querySelectorAll('.proj-slideshow__dot');
  var prev   = ss.querySelector('.proj-slideshow__arrow--prev');
  var next   = ss.querySelector('.proj-slideshow__arrow--next');
  var cur    = 0;
  var timer;

  function go(n) {
    slides[cur].classList.remove('active');
    dots[cur].classList.remove('active');
    cur = (n + slides.length) % slides.length;
    slides[cur].classList.add('active');
    dots[cur].classList.add('active');
  }

  function startAuto() { timer = setInterval(function() { go(cur + 1); }, 3500); }
  function stopAuto()  { clearInterval(timer); }

  slides[0].classList.add('active');
  startAuto();
  ss.addEventListener('mouseenter', stopAuto);
  ss.addEventListener('mouseleave', startAuto);
  prev.addEventListener('click', function() { stopAuto(); go(cur - 1); startAuto(); });
  next.addEventListener('click', function() { stopAuto(); go(cur + 1); startAuto(); });
  dots.forEach(function(d, i) { d.addEventListener('click', function() { stopAuto(); go(i); startAuto(); }); });

  // Touch swipe
  var touchX = 0;
  ss.addEventListener('touchstart', function(e) { touchX = e.touches[0].clientX; }, { passive: true });
  ss.addEventListener('touchend', function(e) {
    var dx = e.changedTouches[0].clientX - touchX;
    if (Math.abs(dx) > 40) { stopAuto(); go(dx < 0 ? cur + 1 : cur - 1); startAuto(); }
  }, { passive: true });
});
</script>
